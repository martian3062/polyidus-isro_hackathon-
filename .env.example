# ─── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-a-long-random-production-secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=overlay.settings.development

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (default for dev — no setup needed)
DATABASE_URL=sqlite:///db.sqlite3
# Supabase Postgres (uncomment for production)
# DATABASE_URL=postgres://db_user@db_host:5432/overlay

# ─── Infrastructure ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
NATS_URL=nats://localhost:4222
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ─── LLM providers ────────────────────────────────────────────────────────────
OVERLAY_LLM_BACKEND=groq
OVERLAY_LOCAL_MODEL=phi3:3.8b-mini-4k-instruct-q4_K_M
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
HF_TOKEN=your_huggingface_token_here
HUGGINGFACE_TOKEN=your_huggingface_token_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# ─── Overlay agent config ───────────────────────────────────────────────────────
A2A_BUS_BACKEND=redis          # redis | nats | websocket
ML_DEVICE=cpu                  # cpu | cuda
ENABLE_GUARDIAN=True
LATENCY_BUDGET_MS=500

# ─── Security ─────────────────────────────────────────────────────────────────
# KEYCLOAK_URL=http://localhost:8080
# KEYCLOAK_REALM=overlay
# KEYCLOAK_CLIENT_ID=overlay-backend
# KEYCLOAK_CLIENT_SECRET=...

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
